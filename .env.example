# =============================================================================
# secure-mcp-gateway - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# =============================================================================

# --- ORY Hydra ---
# OAuth2/OIDC token validation endpoint.
HYDRA_ADMIN_URL=http://localhost:4445
HYDRA_PUBLIC_URL=http://localhost:4444

# --- OPA (Open Policy Agent) ---
# Policy evaluation endpoint.
OPA_URL=http://localhost:8181

# --- Proxy ---
# Upstream MCP server to proxy requests to.
UPSTREAM_MCP_URL=http://localhost:3001
# Address for the HTTP proxy to listen on.
PROXY_LISTEN_ADDR=:8080

# --- Audit Logging ---
# Output path for audit logs. Use "stdout" for console output.
AUDIT_LOG_PATH=stdout

# --- gRPC ---
# Address for the gRPC management API to listen on.
GRPC_LISTEN_ADDR=:9090
